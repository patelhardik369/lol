# Copy to `.env` and fill in. `.env` is gitignored. DRY_RUN needs NO secrets.
# All names here map 1:1 to bot/config.py (Config.from_env).

# ---- mode -------------------------------------------------------------------
POLYBOT_MODE=DRY_RUN            # DRY_RUN (default, safe) | LIVE (Phase 5)

# ---- Binance signal source (SPOT BTCUSDT only) ------------------------------
BINANCE_BASE_URL=https://api.binance.com
BINANCE_SYMBOL=BTCUSDT
BINANCE_INTERVAL=5m
BINANCE_KLINES_LIMIT=50

# ---- Polymarket endpoints ---------------------------------------------------
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYGON_CHAIN_ID=137

# ---- Polymarket credentials (LEAVE BLANK for DRY_RUN; required only in LIVE)-
POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_FUNDER_ADDRESS=

# ---- strategy thresholds (share prices, 0..1) -------------------------------
ENTRY_PRICE=0.58               # entry-band MAX (signal side must be <= this)
ENTRY_MIN_PRICE=0.45           # entry-band MIN (skip deep-underdog entries)
HEDGE_OPPOSITE_PRICE=0.52
FAVORITE_THRESHOLD=0.80
INSURANCE_THRESHOLD=0.10
PRICE_TOLERANCE=0.01
FAVORITE_MARGIN_USD=0.0        # favorite buys until fav_shares > cost + this
LOCK_MARGIN_USD=0.0            # min guaranteed profit ($) required to lock (0 = any profit)
ENABLE_LOSS_HEDGE=false        # literal-spec adverse hedge at ~0.52 (off: it blocks profit-locks)
# NOTE: entry is now PURE SIGNAL (enter the signal side at any price); ENTRY_PRICE /
# ENTRY_MIN_PRICE above are retained but no longer gate entry.

# ---- sizing (Polymarket floors: >=5 shares AND >=$1 notional) ---------------
BASE_NOTIONAL_USD=1.0
MIN_SHARES=5
MIN_NOTIONAL_USD=1.0

# ---- maker order behavior + loop cadence ------------------------------------
POST_ONLY=true
DEFAULT_TICK_SIZE=0.01
UNFILLED_TIMEOUT_SEC=3          # cancel & re-quote if not filled within 3s
INNER_TICK_SEC=1               # fast in-window evaluation cadence
ENTRY_STOP_BUFFER_SEC=10       # stop opening new entries this close to window end
MIN_ACTION_BUFFER_SEC=2        # place no orders at all in the last N seconds
RESOLVE_DELAY_SEC=150         # wait this long after a window ends, then read the REAL settled outcome

# ---- signal engine ----------------------------------------------------------
SIGNAL_NAME=momentum
SIGNAL_LOOKBACK=3
SIGNAL_MIN_PCT=0.0             # min |return| over lookback to commit to a side

# ---- paths / logging --------------------------------------------------------
DATA_DIR=data
LOGS_DIR=logs
LOG_LEVEL=INFO
